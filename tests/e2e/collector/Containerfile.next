# "Next" variant: same shape as Containerfile but with newer pins on the
# heavy library stack so we can validate the project against versions that
# are likely to be deployed in 2025-2026 production environments.
#
# Bumps vs the baseline Containerfile:
#   * Debian base: bookworm-slim -> trixie-slim     (newer system libs)
#   * gRPC:        v1.45.2 (May 2022) -> v1.66.0 (Aug 2024)
#       Brings ~2 years of API stabilization, abseil bumps, etc.
#       v1.66 is the most-recent LTS-ish line widely available.
#   * Protobuf:    v3.x (bundled w/ gRPC v1.45) -> v5.x (bundled w/ v1.66)
#       Major version bump — breaking changes possible in generated code
#       and in MessageToJsonString / utility headers.
#   * librdkafka:  apt-installed (trixie ~ 2.6.x)
#   * libspdlog:   apt-installed (trixie ~ 1.14.x)
#
# First build is slow (gRPC + protobuf from source); subsequent builds reuse
# the cached layer.
ARG VERSION=trixie-slim
FROM debian:${VERSION}

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash git ca-certificates cmake build-essential autoconf libtool \
        pkg-config \
        libjsoncpp-dev librdkafka-dev libconfig++-dev libspdlog-dev \
        libzmq3-dev cppzmq-dev \
    && rm -rf /var/lib/apt/lists/*

ENV INSTALL_DIR=/opt/grpc-install
ENV PATH=${INSTALL_DIR}/bin:${PATH}
ENV LD_LIBRARY_PATH=${INSTALL_DIR}/lib:${INSTALL_DIR}/lib64

RUN git clone --recurse-submodules -b v1.66.0 --depth 1 --shallow-submodules \
        https://github.com/grpc/grpc /tmp/grpc \
    && cmake -S /tmp/grpc -B /tmp/grpc/build \
        -DgRPC_INSTALL=ON \
        -DCMAKE_BUILD_TYPE=Release \
        -DgRPC_BUILD_TESTS=OFF \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_DIR} \
        -DABSL_PROPAGATE_CXX_STD=ON \
        -DgRPC_ABSL_PROVIDER=module \
        -DgRPC_CARES_PROVIDER=module \
        -DgRPC_PROTOBUF_PROVIDER=module \
        -DgRPC_RE2_PROVIDER=module \
        -DgRPC_SSL_PROVIDER=module \
        -DgRPC_ZLIB_PROVIDER=module \
    && cmake --build /tmp/grpc/build -j"$(nproc)" \
    && cmake --install /tmp/grpc/build \
    && rm -rf /tmp/grpc

WORKDIR /src
COPY CMakeLists.txt VERSION ./
COPY proto ./proto
COPY src ./src

# The checked-in src/proto/*.pb.{h,cc} were generated by an older protoc and
# reference headers that have been removed in newer protobuf. Wipe them so
# CMake's add_custom_command regenerates them with the new protoc.
RUN find /src/src/proto -name '*.pb.cc' -delete \
    && find /src/src/proto -name '*.pb.h'  -delete

RUN cmake -S /src -B /src/build -DCMAKE_PREFIX_PATH=${INSTALL_DIR} \
    && cmake --build /src/build -j"$(nproc)" \
    && cp /src/bin/mdt_dialout_collector /usr/local/bin/

RUN mkdir -p /etc/opt/mdt-dialout-collector

ENTRYPOINT ["/usr/local/bin/mdt_dialout_collector"]
CMD ["-f", "/etc/opt/mdt-dialout-collector/mdt_dialout_collector.conf"]
