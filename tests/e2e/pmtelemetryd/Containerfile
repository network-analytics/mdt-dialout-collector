# pmtelemetryd e2e: builds pmacct/pmtelemetryd with the embedded gRPC
# dial-out collector linked against THIS branch's libgrpc_collector.
#
# Layer ordering is deliberate: the slow gRPC + pmacct compiles sit BEFORE
# the local-source COPY so that iterating on src/ rebuilds only the
# library + relink (fast), not the whole stack.
#
# First build: ~20-25 min (gRPC ~12 min, pmacct ~5 min, lib rebuild ~2 min).
# Subsequent builds with only src/ changes: ~3-5 min.
ARG VERSION=bookworm-slim
FROM debian:${VERSION}

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash git ca-certificates curl cmake build-essential autoconf automake \
        libtool pkg-config bison flex \
        libjsoncpp-dev librdkafka-dev libconfig++-dev libspdlog-dev \
        libzmq3-dev cppzmq-dev libfmt-dev libssl-dev \
        libjansson-dev libpcap-dev libnuma-dev \
    && rm -rf /var/lib/apt/lists/*

# gRPC v1.45.2 from source (matches install.sh's pinned version).
ENV GRPC_INSTALL_DIR=/opt/grpc-install
ENV PATH=${GRPC_INSTALL_DIR}/bin:${PATH}
ENV LD_LIBRARY_PATH=${GRPC_INSTALL_DIR}/lib:${GRPC_INSTALL_DIR}/lib64
ENV PKG_CONFIG_PATH=${GRPC_INSTALL_DIR}/lib/pkgconfig:${GRPC_INSTALL_DIR}/lib64/pkgconfig

RUN git clone --recurse-submodules -b v1.45.2 --depth 1 --shallow-submodules \
        https://github.com/grpc/grpc /tmp/grpc \
    && cmake -S /tmp/grpc -B /tmp/grpc/build \
        -DgRPC_INSTALL=ON -DCMAKE_BUILD_TYPE=Release -DgRPC_BUILD_TESTS=OFF \
        -DCMAKE_INSTALL_PREFIX=${GRPC_INSTALL_DIR} \
        -DABSL_PROPAGATE_CXX_STD=ON \
        -DgRPC_ABSL_PROVIDER=module -DgRPC_CARES_PROVIDER=module \
        -DgRPC_PROTOBUF_PROVIDER=module -DgRPC_RE2_PROVIDER=module \
        -DgRPC_SSL_PROVIDER=module -DgRPC_ZLIB_PROVIDER=module \
    && cmake --build /tmp/grpc/build -j"$(nproc)" \
    && cmake --install /tmp/grpc/build \
    && rm -rf /tmp/grpc

# install.sh -l symlinks the protoc plugin here.
RUN ln -sf ${GRPC_INSTALL_DIR}/bin/grpc_cpp_plugin /usr/local/bin/grpc_cpp_plugin

# pmacct from a pinned upstream commit (cacheable). After this layer,
# rebuilding only the local mdt-dialout-collector source is fast.
# Pinned upstream master commit (most-recent code as of integration).
# Bump PMACCT_REF below to track newer master.
ARG PMACCT_REF=bc75aad080470e2070fd5a557f0023d612e063b5
RUN git clone https://github.com/pmacct/pmacct.git /tmp/pmacct \
    && cd /tmp/pmacct \
    && git checkout ${PMACCT_REF}

# --- Local source layer (rebuilds when src/ changes) ---
WORKDIR /opt/mdt-dialout-collector
COPY configure.ac autogen.sh Makefile.am VERSION grpc-collector.pc.in ./
COPY config_m4 ./config_m4
COPY proto ./proto
COPY src ./src
# install.sh -l's autogen+configure+make+install equivalent.
RUN ./autogen.sh \
    && CPPFLAGS="-I${GRPC_INSTALL_DIR}/include -I/usr/include/jsoncpp" \
       ./configure --prefix=/usr/local \
    && make -j"$(nproc)" \
    && make install \
    && ldconfig

# Build pmtelemetryd with the embedded collector linked against our .so.
# Note: dropped --enable-debug compared to the README — it appends
# -Werror to CFLAGS unconditionally, and pmacct v1.7.8 trips a gcc 12
# -Wuse-after-free false positive in util.c. We don't need debug symbols
# for this e2e validation, just a working pmtelemetryd binary.
RUN cd /tmp/pmacct \
    && ./autogen.sh \
    && ./configure --enable-zmq --enable-jansson \
                   --enable-kafka --enable-grpc-collector \
    && make -j"$(nproc)" \
    && make install

RUN mkdir -p /etc/pmacct /var/log/pmacct /var/run

# Configs are bind-mounted at run time so we can iterate without rebuild.
ENTRYPOINT ["/usr/local/sbin/pmtelemetryd"]
CMD ["-f", "/etc/pmacct/pmtelemetryd.conf"]
