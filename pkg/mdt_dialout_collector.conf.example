# mdt-dialout-collector — example configuration.
# See /usr/share/doc/mdt-dialout-collector/CONFIG-KEYS for the full key list.

iface = "eth0";
writer_id = "mdt-collector-01";
core_pid_folder = "/var/run/mdt-dialout-collector/";

# Listening sockets per vendor. Both IPv4 and IPv6 forms are accepted:
#   "0.0.0.0:10007"      — any IPv4
#   "[::]:10007"         — any IPv6 (Linux dual-stack accepts v4-mapped too)
#   "[2001:db8::1]:10007"
socket_cisco   = "0.0.0.0:10007";
socket_juniper = "0.0.0.0:10008";
socket_nokia   = "0.0.0.0:10009";
socket_huawei  = "0.0.0.0:10010";

cisco_workers   = "1";
juniper_workers = "1";
nokia_workers   = "1";
huawei_workers  = "1";

# 0 = unlimited replies per session.
replies_cisco   = "0";
replies_juniper = "0";
replies_nokia   = "0";
replies_huawei  = "0";

# Set to "false" if SO_BINDTODEVICE is not desired (e.g. inside a container
# where the daemon does not have CAP_NET_RAW).
so_bindtodevice_check = "false";

# Server-side TLS (optional). Off by default; set to "true" and provide
# the cert/key paths to enable TLS on every vendor's port.
#enable_tls    = "true";
#tls_cert_path = "/etc/opt/mdt-dialout-collector/tls/server.crt";
#tls_key_path  = "/etc/opt/mdt-dialout-collector/tls/server.key";

# Data manipulation toggles (cisco-XOR — exactly one of the two must be true).
enable_cisco_gpbkv2json             = "true";
enable_cisco_message_to_json_string = "false";

# Data delivery: "kafka" or "zmq".
data_delivery_method = "kafka";

bootstrap_servers = "kafka.example.org:9092";
topic             = "mdt-collector";
client_id         = "mdt-collector-01";
security_protocol = "plaintext";
log_level         = "0";

# Logging.
console_log = "false";
syslog      = "true";
spdlog_level = "info";
